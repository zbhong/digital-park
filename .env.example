# ============================================================
# 智慧园区综合管理平台 - 环境变量示例文件
# 使用方法：复制此文件为 .env 并修改其中的值
# cp .env.example .env
# ============================================================

# ---------- MySQL 配置 ----------
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=请修改为强密码
MYSQL_DATABASE=digital_park

# ---------- Redis 配置 ----------
REDIS_PORT=6379
REDIS_PASSWORD=请修改为强密码

# ---------- JWT 配置 ----------
JWT_SECRET=请修改为随机密钥字符串

# ---------- 后端服务配置 ----------
BACKEND_PORT=8080

# ---------- Nginx 配置 ----------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
